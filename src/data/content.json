[
  { "id": 1, "category": "İtiraf", "text": "Lisede yoklama alınırken arkadaşıma da var dedim, çocuk şehir dışındaymış.", "views": 312, "reactions": { "heart": 44, "laugh": 32, "fire": 12, "shock": 9, "sad": 6, "clap": 20 }, "createdAt": "2026-03-01T09:00:00Z" },
  { "id": 2, "category": "İtiraf", "text": "Evdeki son baklavayı ben yedim ama suçu misafire attım.", "views": 228, "reactions": { "heart": 20, "laugh": 51, "fire": 8, "shock": 5, "sad": 3, "clap": 11 }, "createdAt": "2026-03-01T10:10:00Z" },
  { "id": 3, "category": "İtiraf", "text": "Toplantıda not alıyormuş gibi yapıp alışveriş listesi hazırladım.", "views": 405, "reactions": { "heart": 35, "laugh": 74, "fire": 19, "shock": 10, "sad": 4, "clap": 25 }, "createdAt": "2026-03-01T11:20:00Z" },
  { "id": 4, "category": "İtiraf", "text": "Çok övdüğüm filmi hiç izlemedim, fragmanla idare ettim.", "views": 517, "reactions": { "heart": 61, "laugh": 88, "fire": 20, "shock": 16, "sad": 2, "clap": 31 }, "createdAt": "2026-03-01T12:30:00Z" },
  { "id": 5, "category": "İtiraf", "text": "Sevgilime sürpriz aldım dedim, aslında indirimde görünce kendime almıştım.", "views": 290, "reactions": { "heart": 27, "laugh": 63, "fire": 17, "shock": 7, "sad": 5, "clap": 14 }, "createdAt": "2026-03-01T13:40:00Z" },
  { "id": 6, "category": "İtiraf", "text": "Kardeşimin puzzle'ını gizlice ben tamamladım, o da kendini dahi sandı.", "views": 376, "reactions": { "heart": 48, "laugh": 69, "fire": 11, "shock": 6, "sad": 3, "clap": 22 }, "createdAt": "2026-03-01T14:50:00Z" },
  { "id": 7, "category": "İtiraf", "text": "Sunumda takılınca internet gitti numarası yaptım.", "views": 684, "reactions": { "heart": 74, "laugh": 129, "fire": 42, "shock": 28, "sad": 6, "clap": 45 }, "createdAt": "2026-03-01T16:00:00Z" },
  { "id": 8, "category": "İtiraf", "text": "Arkadaşımın doğum gününü unuttum, takvime yazmışım gibi davrandım.", "views": 241, "reactions": { "heart": 30, "laugh": 37, "fire": 9, "shock": 8, "sad": 10, "clap": 13 }, "createdAt": "2026-03-01T17:10:00Z" },
  { "id": 9, "category": "İtiraf", "text": "CV'ye ileri Excel yazdım, pivot table'ı dün öğrendim.", "views": 922, "reactions": { "heart": 91, "laugh": 203, "fire": 55, "shock": 26, "sad": 7, "clap": 77 }, "createdAt": "2026-03-01T18:20:00Z" },
  { "id": 10, "category": "İtiraf", "text": "Evde bitki bakıyorum dedim, annem sulamasa hepsi kururdu.", "views": 199, "reactions": { "heart": 24, "laugh": 40, "fire": 6, "shock": 4, "sad": 8, "clap": 10 }, "createdAt": "2026-03-01T19:30:00Z" },

  { "id": 11, "category": "Sır", "text": "Mahalle grubundaki anonim hesabın sahibi benim.", "views": 650, "reactions": { "heart": 16, "laugh": 120, "fire": 59, "shock": 80, "sad": 4, "clap": 23 }, "createdAt": "2026-03-02T09:00:00Z" },
  { "id": 12, "category": "Sır", "text": "Aile tarifindeki gizli malzeme, marketten aldığım hazır sos.", "views": 433, "reactions": { "heart": 31, "laugh": 62, "fire": 15, "shock": 21, "sad": 1, "clap": 42 }, "createdAt": "2026-03-02T10:10:00Z" },
  { "id": 13, "category": "Sır", "text": "Ofiste kahve makinesini ben bozmadım, ama suç bende kaldı ve ses etmedim.", "views": 271, "reactions": { "heart": 19, "laugh": 28, "fire": 7, "shock": 19, "sad": 11, "clap": 12 }, "createdAt": "2026-03-02T11:20:00Z" },
  { "id": 14, "category": "Sır", "text": "Yıllardır herkesin sevdiği tatlıyı ben dışarıdan alıp kendi yapmışım gibi sunuyorum.", "views": 508, "reactions": { "heart": 39, "laugh": 71, "fire": 18, "shock": 31, "sad": 2, "clap": 36 }, "createdAt": "2026-03-02T12:30:00Z" },
  { "id": 15, "category": "Sır", "text": "Kuzenimin hediyesini yanlışlıkla ben kırdım, o güne kadar sakladım.", "views": 312, "reactions": { "heart": 23, "laugh": 14, "fire": 5, "shock": 40, "sad": 26, "clap": 9 }, "createdAt": "2026-03-02T13:40:00Z" },
  { "id": 16, "category": "Sır", "text": "Patronun köpeğini ben gezdirmiyorum, köpek beni gezdiriyor.", "views": 205, "reactions": { "heart": 18, "laugh": 46, "fire": 10, "shock": 12, "sad": 0, "clap": 8 }, "createdAt": "2026-03-02T14:50:00Z" },
  { "id": 17, "category": "Sır", "text": "Komşunun kapısına yanlışlıkla gelen kargoyu açtım, sonra bantlayıp geri verdim.", "views": 390, "reactions": { "heart": 12, "laugh": 39, "fire": 14, "shock": 58, "sad": 3, "clap": 11 }, "createdAt": "2026-03-02T16:00:00Z" },
  { "id": 18, "category": "Sır", "text": "Evde kırılan vazoyu kediye attım ama aslında ben düşürdüm.", "views": 177, "reactions": { "heart": 10, "laugh": 25, "fire": 4, "shock": 29, "sad": 8, "clap": 5 }, "createdAt": "2026-03-02T17:10:00Z" },
  { "id": 19, "category": "Sır", "text": "Çalışma grubunda konuşulanları not etmiyorum, sadece başımı sallıyorum.", "views": 264, "reactions": { "heart": 15, "laugh": 41, "fire": 9, "shock": 18, "sad": 6, "clap": 10 }, "createdAt": "2026-03-02T18:20:00Z" },
  { "id": 20, "category": "Sır", "text": "Aynı kitabı ikinci kez okuyorum ama herkese yeni keşfettim diyorum.", "views": 149, "reactions": { "heart": 17, "laugh": 20, "fire": 3, "shock": 7, "sad": 2, "clap": 6 }, "createdAt": "2026-03-02T19:30:00Z" },

  { "id": 21, "category": "Komik", "text": "Markette yabancı birine baba diye seslendim, indirimleri suçlayıp kaçtım.", "views": 702, "reactions": { "heart": 20, "laugh": 311, "fire": 63, "shock": 44, "sad": 2, "clap": 28 }, "createdAt": "2026-03-03T09:00:00Z" },
  { "id": 22, "category": "Komik", "text": "Uykumda sunum yapmışım, sabah ailem alkışla uyandırdı.", "views": 488, "reactions": { "heart": 17, "laugh": 220, "fire": 52, "shock": 19, "sad": 1, "clap": 24 }, "createdAt": "2026-03-03T10:10:00Z" },
  { "id": 23, "category": "Komik", "text": "Spor salonuna 4 ay gitmedim, uygulamada kendimi aktif gösteriyorum.", "views": 356, "reactions": { "heart": 14, "laugh": 166, "fire": 28, "shock": 15, "sad": 3, "clap": 9 }, "createdAt": "2026-03-03T11:20:00Z" },
  { "id": 24, "category": "Komik", "text": "Kafede laptopu açıp çok yoğun görünmeye çalışırken film izliyordum.", "views": 615, "reactions": { "heart": 26, "laugh": 247, "fire": 44, "shock": 20, "sad": 1, "clap": 32 }, "createdAt": "2026-03-03T12:30:00Z" },
  { "id": 25, "category": "Komik", "text": "Yanlış kişiye sesli mesaj attım, kendime motivasyon konuşması karşı tarafa gitti.", "views": 530, "reactions": { "heart": 18, "laugh": 231, "fire": 37, "shock": 52, "sad": 2, "clap": 16 }, "createdAt": "2026-03-03T13:40:00Z" },
  { "id": 26, "category": "Komik", "text": "Zoom'da filtreyi kapatamadım, toplantıyı tavşan suratla bitirdim.", "views": 980, "reactions": { "heart": 41, "laugh": 430, "fire": 88, "shock": 77, "sad": 4, "clap": 55 }, "createdAt": "2026-03-03T14:50:00Z" },
  { "id": 27, "category": "Komik", "text": "Navigasyon 'sağa dön' dedi, ben de hayatımı sorguladım.", "views": 240, "reactions": { "heart": 12, "laugh": 95, "fire": 18, "shock": 11, "sad": 1, "clap": 7 }, "createdAt": "2026-03-03T16:00:00Z" },
  { "id": 28, "category": "Komik", "text": "Otobüste ineceğim durağı kaçırınca şoföre turistik geziye çıktım dedim.", "views": 320, "reactions": { "heart": 10, "laugh": 142, "fire": 22, "shock": 9, "sad": 1, "clap": 8 }, "createdAt": "2026-03-03T17:10:00Z" },
  { "id": 29, "category": "Komik", "text": "Telefon sessizdeydi, 20 çağrıyı görmeyince uzayda mıyım diye sordular.", "views": 189, "reactions": { "heart": 8, "laugh": 74, "fire": 9, "shock": 6, "sad": 2, "clap": 5 }, "createdAt": "2026-03-03T18:20:00Z" },
  { "id": 30, "category": "Komik", "text": "Hızlı yürüyüş yaparken müziğe kaptırıp markette dans ettim.", "views": 410, "reactions": { "heart": 15, "laugh": 181, "fire": 27, "shock": 13, "sad": 1, "clap": 12 }, "createdAt": "2026-03-03T19:30:00Z" },

  { "id": 31, "category": "Pişmanlık", "text": "Yıllar önce kırdığım kalbi bugün bile telafi edemedim.", "views": 840, "reactions": { "heart": 120, "laugh": 3, "fire": 9, "shock": 35, "sad": 230, "clap": 18 }, "createdAt": "2026-03-04T09:00:00Z" },
  { "id": 32, "category": "Pişmanlık", "text": "Çok değerli bir dostluğu gurur yüzünden kaybettim.", "views": 903, "reactions": { "heart": 141, "laugh": 2, "fire": 8, "shock": 29, "sad": 261, "clap": 21 }, "createdAt": "2026-03-04T10:10:00Z" },
  { "id": 33, "category": "Pişmanlık", "text": "Ders çalışmak yerine erteledim, şimdi zamanı geri alamıyorum.", "views": 640, "reactions": { "heart": 98, "laugh": 5, "fire": 17, "shock": 14, "sad": 145, "clap": 31 }, "createdAt": "2026-03-04T11:20:00Z" },
  { "id": 34, "category": "Pişmanlık", "text": "Babamla son konuşmamızda sesimi yükselttim, keşke yapmasaydım.", "views": 1205, "reactions": { "heart": 210, "laugh": 0, "fire": 4, "shock": 28, "sad": 430, "clap": 13 }, "createdAt": "2026-03-04T12:30:00Z" },
  { "id": 35, "category": "Pişmanlık", "text": "Sağlığımı ihmal ettim, şimdi küçük şeyler bile zor geliyor.", "views": 578, "reactions": { "heart": 87, "laugh": 1, "fire": 12, "shock": 11, "sad": 121, "clap": 19 }, "createdAt": "2026-03-04T13:40:00Z" },
  { "id": 36, "category": "Pişmanlık", "text": "Birine haksızlık yaptığımı çok geç fark ettim.", "views": 490, "reactions": { "heart": 76, "laugh": 2, "fire": 6, "shock": 17, "sad": 103, "clap": 15 }, "createdAt": "2026-03-04T14:50:00Z" },
  { "id": 37, "category": "Pişmanlık", "text": "Ailemle daha fazla vakit geçirmek yerine sürekli işi seçtim.", "views": 995, "reactions": { "heart": 188, "laugh": 1, "fire": 10, "shock": 24, "sad": 301, "clap": 22 }, "createdAt": "2026-03-04T16:00:00Z" },
  { "id": 38, "category": "Pişmanlık", "text": "Arkadaşım yardım isterken meşgulüm deyip geçtim, sonra çok geç oldu.", "views": 860, "reactions": { "heart": 166, "laugh": 0, "fire": 5, "shock": 33, "sad": 255, "clap": 14 }, "createdAt": "2026-03-04T17:10:00Z" },
  { "id": 39, "category": "Pişmanlık", "text": "Kendime hiç şans vermeden vazgeçtim, en çok buna üzülüyorum.", "views": 530, "reactions": { "heart": 80, "laugh": 2, "fire": 11, "shock": 10, "sad": 118, "clap": 20 }, "createdAt": "2026-03-04T18:20:00Z" },
  { "id": 40, "category": "Pişmanlık", "text": "Bir cümle yüzünden yıllık bir emek çöpe gitti.", "views": 444, "reactions": { "heart": 64, "laugh": 1, "fire": 7, "shock": 13, "sad": 99, "clap": 12 }, "createdAt": "2026-03-04T19:30:00Z" },

  { "id": 41, "category": "Aşk", "text": "Aynı kahvede her gün onu görmek için farklı saat deniyorum.", "views": 760, "reactions": { "heart": 212, "laugh": 18, "fire": 70, "shock": 9, "sad": 22, "clap": 34 }, "createdAt": "2026-03-05T09:00:00Z" },
  { "id": 42, "category": "Aşk", "text": "Mesajını geç görünce sakin kalmaya çalışıyorum ama içim kıyamet.", "views": 645, "reactions": { "heart": 175, "laugh": 14, "fire": 43, "shock": 10, "sad": 40, "clap": 20 }, "createdAt": "2026-03-05T10:10:00Z" },
  { "id": 43, "category": "Aşk", "text": "Onunla yürüdüğüm sokaklardan tek başıma geçemiyorum.", "views": 820, "reactions": { "heart": 250, "laugh": 6, "fire": 38, "shock": 11, "sad": 120, "clap": 17 }, "createdAt": "2026-03-05T11:20:00Z" },
  { "id": 44, "category": "Aşk", "text": "Konu ne olursa olsun onu anlatacak bir yol buluyorum.", "views": 510, "reactions": { "heart": 132, "laugh": 21, "fire": 29, "shock": 7, "sad": 18, "clap": 16 }, "createdAt": "2026-03-05T12:30:00Z" },
  { "id": 45, "category": "Aşk", "text": "Ayrıldıktan sonra bile en sevdiği şarkıyı atlayamıyorum.", "views": 934, "reactions": { "heart": 281, "laugh": 5, "fire": 33, "shock": 8, "sad": 190, "clap": 14 }, "createdAt": "2026-03-05T13:40:00Z" },
  { "id": 46, "category": "Aşk", "text": "Elini ilk tuttuğum günü takvimde hala işaretli tutuyorum.", "views": 402, "reactions": { "heart": 119, "laugh": 8, "fire": 21, "shock": 4, "sad": 26, "clap": 13 }, "createdAt": "2026-03-05T14:50:00Z" },
  { "id": 47, "category": "Aşk", "text": "Onun için kahveyi şekersiz içmeye başladım, şimdi alıştım.", "views": 358, "reactions": { "heart": 101, "laugh": 17, "fire": 18, "shock": 5, "sad": 10, "clap": 12 }, "createdAt": "2026-03-05T16:00:00Z" },
  { "id": 48, "category": "Aşk", "text": "Bir bakışıyla bütün günüm değişiyor, bunu saklayamıyorum.", "views": 689, "reactions": { "heart": 204, "laugh": 9, "fire": 41, "shock": 8, "sad": 15, "clap": 22 }, "createdAt": "2026-03-05T17:10:00Z" },
  { "id": 49, "category": "Aşk", "text": "Senden vazgeçtim derken aslında kendime yalan söyledim.", "views": 1002, "reactions": { "heart": 322, "laugh": 4, "fire": 36, "shock": 14, "sad": 230, "clap": 18 }, "createdAt": "2026-03-05T18:20:00Z" },
  { "id": 50, "category": "Aşk", "text": "Bazen sadece yanında sessizce oturmak bile yetiyor.", "views": 477, "reactions": { "heart": 140, "laugh": 7, "fire": 17, "shock": 3, "sad": 12, "clap": 15 }, "createdAt": "2026-03-05T19:30:00Z" },

  { "id": 51, "category": "Kariyer", "text": "İlk iş günümde yazıcıyı bozdum, herkes sakin kal dedi.", "views": 390, "reactions": { "heart": 41, "laugh": 52, "fire": 16, "shock": 14, "sad": 4, "clap": 23 }, "createdAt": "2026-03-06T09:00:00Z" },
  { "id": 52, "category": "Kariyer", "text": "Maaş zammı istemek için üç gün prova yaptım ama yine kekeledim.", "views": 610, "reactions": { "heart": 87, "laugh": 64, "fire": 28, "shock": 12, "sad": 6, "clap": 38 }, "createdAt": "2026-03-06T10:10:00Z" },
  { "id": 53, "category": "Kariyer", "text": "Yeni işe alışmak için herkesten önce gelip not tuttum.", "views": 355, "reactions": { "heart": 52, "laugh": 21, "fire": 24, "shock": 5, "sad": 3, "clap": 29 }, "createdAt": "2026-03-06T11:20:00Z" },
  { "id": 54, "category": "Kariyer", "text": "Toplantıda yanlış dosyayı açtım, özgüvenle devam edince kimse fark etmedi.", "views": 740, "reactions": { "heart": 73, "laugh": 118, "fire": 39, "shock": 20, "sad": 4, "clap": 47 }, "createdAt": "2026-03-06T12:30:00Z" },
  { "id": 55, "category": "Kariyer", "text": "Patronun verdiği görevi anlamadım, ama iyi soru sorup kurtardım.", "views": 420, "reactions": { "heart": 55, "laugh": 34, "fire": 22, "shock": 7, "sad": 2, "clap": 30 }, "createdAt": "2026-03-06T13:40:00Z" },
  { "id": 56, "category": "Kariyer", "text": "Yorulduğumu geç fark ettim, bir hafta izin hayat kurtardı.", "views": 530, "reactions": { "heart": 91, "laugh": 9, "fire": 27, "shock": 6, "sad": 18, "clap": 36 }, "createdAt": "2026-03-06T14:50:00Z" },
  { "id": 57, "category": "Kariyer", "text": "LinkedIn'de aktif görünmek için kahveyle poz veriyorum.", "views": 298, "reactions": { "heart": 26, "laugh": 88, "fire": 12, "shock": 9, "sad": 1, "clap": 14 }, "createdAt": "2026-03-06T16:00:00Z" },
  { "id": 58, "category": "Kariyer", "text": "Mentorumun tek cümlesi bütün yönümü değiştirdi.", "views": 476, "reactions": { "heart": 95, "laugh": 7, "fire": 31, "shock": 4, "sad": 3, "clap": 52 }, "createdAt": "2026-03-06T17:10:00Z" },
  { "id": 59, "category": "Kariyer", "text": "Mülakatta bilmediğimi dürüstçe söyledim, yine de işi aldım.", "views": 865, "reactions": { "heart": 165, "laugh": 22, "fire": 63, "shock": 15, "sad": 4, "clap": 88 }, "createdAt": "2026-03-06T18:20:00Z" },
  { "id": 60, "category": "Kariyer", "text": "Kariyer planı yaptıkça hayat başka şeyler öğretiyor.", "views": 344, "reactions": { "heart": 62, "laugh": 10, "fire": 19, "shock": 5, "sad": 8, "clap": 25 }, "createdAt": "2026-03-06T19:30:00Z" },

  { "id": 61, "category": "Okul", "text": "Sınava bir gece kala başladım, mucizeyi kahveden bekledim.", "views": 720, "reactions": { "heart": 66, "laugh": 140, "fire": 33, "shock": 22, "sad": 9, "clap": 24 }, "createdAt": "2026-03-07T09:00:00Z" },
  { "id": 62, "category": "Okul", "text": "Derste hocaya hak verdim, sınıf bana ters baktı.", "views": 260, "reactions": { "heart": 19, "laugh": 58, "fire": 9, "shock": 11, "sad": 2, "clap": 10 }, "createdAt": "2026-03-07T10:10:00Z" },
  { "id": 63, "category": "Okul", "text": "Proje ödevi için kütüphanede sabahladık, dostluğumuz güçlendi.", "views": 438, "reactions": { "heart": 72, "laugh": 15, "fire": 26, "shock": 6, "sad": 4, "clap": 39 }, "createdAt": "2026-03-07T11:20:00Z" },
  { "id": 64, "category": "Okul", "text": "Yanlış sınıfa girip 20 dakika not tuttum.", "views": 590, "reactions": { "heart": 35, "laugh": 210, "fire": 30, "shock": 33, "sad": 2, "clap": 14 }, "createdAt": "2026-03-07T12:30:00Z" },
  { "id": 65, "category": "Okul", "text": "Hocanın sorduğu soruyu anlamadım ama kendimden emin cevapladım.", "views": 402, "reactions": { "heart": 29, "laugh": 112, "fire": 21, "shock": 18, "sad": 2, "clap": 13 }, "createdAt": "2026-03-07T13:40:00Z" },
  { "id": 66, "category": "Okul", "text": "Vize haftası başlayınca odamın temizliği birden önemli oldu.", "views": 355, "reactions": { "heart": 24, "laugh": 96, "fire": 14, "shock": 8, "sad": 5, "clap": 9 }, "createdAt": "2026-03-07T14:50:00Z" },
  { "id": 67, "category": "Okul", "text": "Sunum sırasında kalemim düşmesin diye nefes almayı unuttum.", "views": 310, "reactions": { "heart": 21, "laugh": 70, "fire": 13, "shock": 12, "sad": 3, "clap": 11 }, "createdAt": "2026-03-07T16:00:00Z" },
  { "id": 68, "category": "Okul", "text": "Finalden bir gün önce not isteyen herkese PDF dağıttım, kahraman ilan edildim.", "views": 650, "reactions": { "heart": 110, "laugh": 30, "fire": 45, "shock": 7, "sad": 1, "clap": 66 }, "createdAt": "2026-03-07T17:10:00Z" },
  { "id": 69, "category": "Okul", "text": "Staj raporunu son gece yazıp sabah teslim ettim.", "views": 505, "reactions": { "heart": 48, "laugh": 84, "fire": 24, "shock": 16, "sad": 6, "clap": 20 }, "createdAt": "2026-03-07T18:20:00Z" },
  { "id": 70, "category": "Okul", "text": "Mezuniyet yaklaşınca kampüs daha güzel görünmeye başladı.", "views": 285, "reactions": { "heart": 57, "laugh": 11, "fire": 12, "shock": 4, "sad": 9, "clap": 18 }, "createdAt": "2026-03-07T19:30:00Z" },

  { "id": 71, "category": "Eğlence", "text": "Karaoke gecesinde yanlış şarkı açıldı, yine de devam ettim.", "views": 470, "reactions": { "heart": 29, "laugh": 140, "fire": 34, "shock": 12, "sad": 2, "clap": 19 }, "createdAt": "2026-03-08T09:00:00Z" },
  { "id": 72, "category": "Eğlence", "text": "Arkadaşlarla masa oyununda kuralları sonradan öğrendim.", "views": 260, "reactions": { "heart": 16, "laugh": 72, "fire": 11, "shock": 9, "sad": 1, "clap": 8 }, "createdAt": "2026-03-08T10:10:00Z" },
  { "id": 73, "category": "Eğlence", "text": "Film maratonu yapalım dedik, ilk filmde herkes uyudu.", "views": 390, "reactions": { "heart": 22, "laugh": 103, "fire": 19, "shock": 8, "sad": 4, "clap": 11 }, "createdAt": "2026-03-08T11:20:00Z" },
  { "id": 74, "category": "Eğlence", "text": "Bowling'de top elimden geriye gitti, salon alkışladı.", "views": 820, "reactions": { "heart": 35, "laugh": 321, "fire": 55, "shock": 64, "sad": 3, "clap": 26 }, "createdAt": "2026-03-08T12:30:00Z" },
  { "id": 75, "category": "Eğlence", "text": "Festivalde en sevdiğim şarkıda yağmur başladı, daha da güzel oldu.", "views": 560, "reactions": { "heart": 98, "laugh": 17, "fire": 44, "shock": 5, "sad": 7, "clap": 41 }, "createdAt": "2026-03-08T13:40:00Z" },
  { "id": 76, "category": "Eğlence", "text": "PlayStation turnuvasında son anda kendi kaleme gol attım.", "views": 438, "reactions": { "heart": 18, "laugh": 187, "fire": 33, "shock": 21, "sad": 2, "clap": 10 }, "createdAt": "2026-03-08T14:50:00Z" },
  { "id": 77, "category": "Eğlence", "text": "Lunaparkta en korkusuz bendim, sıra bana gelince vazgeçtim.", "views": 305, "reactions": { "heart": 14, "laugh": 97, "fire": 16, "shock": 19, "sad": 1, "clap": 7 }, "createdAt": "2026-03-08T16:00:00Z" },
  { "id": 78, "category": "Eğlence", "text": "Arkadaş buluşmasına 1 saat erken gidip mekani ben seçmiş gibi davrandım.", "views": 211, "reactions": { "heart": 12, "laugh": 56, "fire": 8, "shock": 6, "sad": 1, "clap": 6 }, "createdAt": "2026-03-08T17:10:00Z" },
  { "id": 79, "category": "Eğlence", "text": "Kamp gecesi hikaye anlatırken kendim korkup sustum.", "views": 480, "reactions": { "heart": 19, "laugh": 154, "fire": 27, "shock": 18, "sad": 2, "clap": 12 }, "createdAt": "2026-03-08T18:20:00Z" },
  { "id": 80, "category": "Eğlence", "text": "Doğum günü sürprizini yanlış güne planladık ama yine kutladık.", "views": 366, "reactions": { "heart": 43, "laugh": 63, "fire": 20, "shock": 9, "sad": 3, "clap": 16 }, "createdAt": "2026-03-08T19:30:00Z" },

  { "id": 81, "category": "Aile", "text": "Annemin attığı sesli mesajlar artık günümün en iyi kısmı.", "views": 590, "reactions": { "heart": 170, "laugh": 26, "fire": 18, "shock": 4, "sad": 22, "clap": 35 }, "createdAt": "2026-03-09T09:00:00Z" },
  { "id": 82, "category": "Aile", "text": "Babamla ilk kez birlikte yemek yaptık, mutfak savaş alanı oldu.", "views": 470, "reactions": { "heart": 120, "laugh": 91, "fire": 22, "shock": 8, "sad": 3, "clap": 24 }, "createdAt": "2026-03-09T10:10:00Z" },
  { "id": 83, "category": "Aile", "text": "Kardeşimle kavga edip 5 dakika sonra birlikte dizi izledik.", "views": 330, "reactions": { "heart": 88, "laugh": 44, "fire": 10, "shock": 5, "sad": 4, "clap": 15 }, "createdAt": "2026-03-09T11:20:00Z" },
  { "id": 84, "category": "Aile", "text": "Bayram sofralarında herkes aynı hikayeyi yeniden anlatıyor.", "views": 420, "reactions": { "heart": 92, "laugh": 70, "fire": 12, "shock": 6, "sad": 2, "clap": 18 }, "createdAt": "2026-03-09T12:30:00Z" },
  { "id": 85, "category": "Aile", "text": "Evde en çok ben dağınık yapıyorum ama en çok ben şikayet ediyorum.", "views": 310, "reactions": { "heart": 54, "laugh": 95, "fire": 9, "shock": 7, "sad": 3, "clap": 10 }, "createdAt": "2026-03-09T13:40:00Z" },
  { "id": 86, "category": "Aile", "text": "Aile grubunda attığım emojiyi yanlış kişiye yollayıp utandım.", "views": 250, "reactions": { "heart": 39, "laugh": 72, "fire": 8, "shock": 11, "sad": 1, "clap": 8 }, "createdAt": "2026-03-09T14:50:00Z" },
  { "id": 87, "category": "Aile", "text": "Dedemin eski hikayelerini kayda almaya başladım, çok kıymetliymiş.", "views": 515, "reactions": { "heart": 164, "laugh": 9, "fire": 20, "shock": 3, "sad": 14, "clap": 41 }, "createdAt": "2026-03-09T16:00:00Z" },
  { "id": 88, "category": "Aile", "text": "Annemin yaptığı çayın tadını hiçbir yerde bulamıyorum.", "views": 620, "reactions": { "heart": 201, "laugh": 12, "fire": 16, "shock": 2, "sad": 18, "clap": 30 }, "createdAt": "2026-03-09T17:10:00Z" },
  { "id": 89, "category": "Aile", "text": "Ailece fotoğraf çekilirken herkes aynı anda farklı yöne baktı.", "views": 280, "reactions": { "heart": 46, "laugh": 83, "fire": 7, "shock": 6, "sad": 1, "clap": 9 }, "createdAt": "2026-03-09T18:20:00Z" },
  { "id": 90, "category": "Aile", "text": "Evdeki en sakin kişi benmişim gibi davranıyorum ama en çabuk ben sinirleniyorum.", "views": 360, "reactions": { "heart": 58, "laugh": 66, "fire": 11, "shock": 9, "sad": 5, "clap": 13 }, "createdAt": "2026-03-09T19:30:00Z" }
]
